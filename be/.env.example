# Sao chép thành .env.local và chỉnh giá trị. Không commit file chứa secret thật.
# Chạy BE: từ thư mục be dùng ./run-with-env.sh (script source .env.local → mvnw).

# --- MySQL (local) ---
# Tạo database: CREATE DATABASE deutsch_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_HOST=localhost
MYSQL_PORT=3306
DB_NAME=deutsch_db
DB_USERNAME=root
DB_PASSWORD=

# Prod / managed MySQL (TLS): MYSQL_USE_SSL=true và bổ sung truststore nếu provider yêu cầu.
# MYSQL_USE_SSL=false

# --- Schema: Flyway (mặc định bật) + Hibernate ddl-auto=none ---
# pom.xml: Flyway 10.x + flyway-mysql.
# DB trống: Flyway chạy V1+V2. DB đã có bảng từ trước: baseline-on-migrate (application.yml) gắn lịch sử ở V2, không CREATE lại.
# Nếu DB đã có bảng do Hibernate cũ và Flyway báo lỗi: tạm đặt
#   FLYWAY_ENABLED=false
#   JPA_DDL_AUTO=update
FLYWAY_ENABLED=true
JPA_DDL_AUTO=none

# --- JWT (dev: >= 32 ký tự, khác change_me nếu bật enforce) ---
# JWT_SECRET=o2oSmFW7LnXfF78If2np6wUzG240a2JnH61zOSjhzfw
# JWT_EXPIRATION_MS=2592000000
# ENFORCE_STRONG_JWT_SECRET=false

# --- Prod / staging: bật enforce và secret mạnh ---
# SPRING_PROFILES_ACTIVE=prod
# ENFORCE_STRONG_JWT_SECRET=true

# --- AI (tùy chọn) ---
# AI_ENABLED=true
# AI_PROVIDER=openai
# OPENAI_API_KEY=

# --- CORS (phân tách bằng dấu phẩy) ---
# Local: http://localhost:3000
# CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000

# --- Legacy Render / PostgreSQL (nhánh này dùng MySQL; bỏ DATABASE_URL postgres nếu còn trong shell) ---
# DATABASE_URL từ Postgres không còn được dùng trên nhánh local-mysql.
