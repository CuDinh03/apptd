# Sao chép thành .env.local và chỉnh giá trị. Không commit file chứa secret thật.

# --- PostgreSQL ---
DB_HOST=localhost
POSTGRES_PORT=5432
DB_NAME=deutsch_db
DB_USERNAME=deutsch_db
DB_PASSWORD=
# Local: prefer hoặc disable. External DATABASE_URL (FQDN sẵn): mặc định require nếu không set PG_SSLMODE.
# Internal DATABASE_URL (host dpg-…) đã mở rộng FQDN: app ép prefer (kể cả khi PG_SSLMODE=require) để tránh EOF JDBC khi auth.
#
# Render Web Service (Docker): DATABASE_URL internal thường là host cụt dpg-…-a — JVM không resolve được
# nếu thiếu suffix. Bắt buộc đặt RENDER_POSTGRES_HOST_SUFFIX đúng region DB, ví dụ:
#   RENDER_POSTGRES_HOST_SUFFIX=singapore-postgres.render.com
# (Blueprint render.yaml đã có; service tạo tay phải thêm tay.)
#
# Render / Docker prod: DATABASE_URL từ “Link database” hoặc dán Internal/External URL.
# Hoặc PGHOST+PGPORT+PGDATABASE+PGUSER+PGPASSWORD. Không có → BE thử localhost và fail.

# --- Schema: Flyway (mặc định bật) + Hibernate ddl-auto=none ---
# pom.xml: Flyway 10.x + flyway-database-postgresql.
# DB trống: Flyway chạy V1+V2. DB đã có bảng từ trước: baseline-on-migrate (application.yml) gắn lịch sử ở V2, không CREATE lại.
# Nếu DB đã có bảng do Hibernate cũ và Flyway báo lỗi: tạm đặt
#   FLYWAY_ENABLED=false
#   JPA_DDL_AUTO=update
FLYWAY_ENABLED=true
JPA_DDL_AUTO=none

# --- JWT (dev: >= 32 ký tự, khác change_me nếu bật enforce) ---
# JWT_SECRET=o2oSmFW7LnXfF78If2np6wUzG240a2JnH61zOSjhzfw
# JWT_EXPIRATION_MS=2592000000
# ENFORCE_STRONG_JWT_SECRET=false

# --- Prod / staging: bật enforce và secret mạnh ---
# SPRING_PROFILES_ACTIVE=prod
# ENFORCE_STRONG_JWT_SECRET=true

# --- AI (tùy chọn) ---
# AI_ENABLED=true
# AI_PROVIDER=openai
# OPENAI_API_KEY=

# --- CORS ---
# CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000
