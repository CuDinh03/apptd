# NEXT_PUBLIC_* được Next.js nhúng vào bundle lúc `next build` (không đọc lại sau khi deploy).
# Nếu production vẫn gọi localhost:8080 → trên host (Render/Vercel/…) thiếu biến này lúc BUILD,
# hoặc chưa deploy lại sau khi sửa env. Cần: set env → Clear build cache (nếu có) → build lại.

# Dev local (copy thành .env.local — không commit)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Production build (đặt trong Environment của web service FE, không chỉ .env máy dev)
# NEXT_PUBLIC_API_URL=https://apptd-backend.onrender.com/api/v1
